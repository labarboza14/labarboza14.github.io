---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);
---

<Layout
  title="Glória Barboza · Python, dados e comunidade em Florianópolis"
  description="Trabalho na interseção entre tecnologia e operação. Python, dados e automação para resolver problemas reais."
  ogImage="/images/gloria-avatar.jpeg"
>
  <div class="container">

    <div class="hero">

      <div class="hero-content">
        <div class="eyebrow">tecnologia &gt; pessoas</div>

        <h1 class="hero-name">
          Olá,<br />sou a <em>Glória</em>
        </h1>

        <div class="hero-role">
          <span>Python</span><span class="hero-sep">·</span>
          <span>dados</span><span class="hero-sep">·</span>
          <span>automação</span><span class="hero-sep">·</span>
          <span>comunidades</span>
        </div>

        <p class="hero-bio">
          Trabalho entre tecnologia e operação.<br /><br />

          Antes de sair escrevendo código, eu tento entender o que está acontecendo.<br />
          Uso dados pra dar contexto, organizo o que está meio caótico
          e automatizo o que está travando.<br /><br />

          Nem sempre é sobre escrever mais código.<br />
          Às vezes, é só sobre enxergar melhor o problema.<br /><br />

          É nesse encontro entre dados, produto e código
          que eu gosto de estar.<br /><br />

          No fim, o que me interessa mesmo é resolver coisas reais,<br />
          com clareza, com intenção<br />
          e pensando em quem está do outro lado.
        </p>

        <div class="hero-chips">
          <a href="https://python.floripa.br/" target="_blank" class="chip blue">💙 Python Floripa</a>
          <a href="https://cumbuca.dev/" target="_blank" class="chip rose">🥥 Cumbuca Dev</a>
          <span class="chip">📍 Florianópolis · SC</span>
        </div>

        <div class="hero-actions">
          <a href="/fio" class="btn btn-rose">minha história</a>
          <a href="https://br.linkedin.com/in/labarboza" target="_blank" rel="noopener" class="btn btn-li">LinkedIn →</a>
          <a href="https://github.com/labarboza14" target="_blank" rel="noopener" class="btn btn-ghost">GitHub</a>
        </div>
      </div>

      <div class="hero-photo-col">
        <div class="hero-photo-frame">
          <img
            src="/images/gloria-avatar.jpeg"
            alt="Glória Barboza sorrindo"
            width="260"
            height="380"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="hero-note">
          <p>
            Código não é o ponto de partida, é consequência.
          </p>
          <p>
            Antes disso tem contexto, tem gente, tem problema real.
            E quase sempre é aí que as coisas travam.
          </p>
        </div>
      </div>

    </div>

    <div class="home-grid">
      <!-- restante do código permanece igual -->
    </div>

  </div>
</Layout>

<style>
.hero {
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 52px;
  align-items: start;
  padding-bottom: 52px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 52px;
}

.hero-content {
  padding-top: 12px;
}

.hero-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.hero-photo-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  padding-top: 12px;
}

.hero-photo-frame {
  width: 280px;
  border-radius: var(--r-xl);
  overflow: hidden;
  border: 2px solid var(--rose-m);
  box-shadow: var(--sh-lg);
  background: var(--bg2);
  aspect-ratio: 3/4;
}

.hero-photo-frame img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.hero-note {
  width: 100%;
  max-width: 260px;
  padding: 16px;
  font-size: 14px;
  line-height: 1.5;
  color: #555;
  background: #f6f7f9;
  border-left: 3px solid var(--rose-m);
  border-radius: 8px;
}

.hero-bio {
  max-width: 520px;
}

@media (max-width: 700px) {
  .hero {
    grid-template-columns: 1fr;
    gap: 28px;
  }

  .hero-photo-col {
    align-items: flex-start;
  }

  .hero-photo-frame {
    width: 180px;
  }

  .hero-note {
    max-width: 100%;
  }
}
</style>
